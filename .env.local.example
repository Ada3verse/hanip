OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
HANIP_USE_MOCK_AI=true
HANIP_ENABLE_LIVE_AI_TESTS=false
HANIP_PIN_PEPPER=replace_with_a_long_random_server_secret
HANIP_SESSION_SECRET=replace_with_a_different_long_random_server_secret
HANIP_RATE_LIMIT_SECRET=replace_with_a_third_random_server_secret
HANIP_ALLOWED_ORIGINS=
# Separate administrator boundary. Store only a scrypt-admin-v1 password hash.
HANIP_ADMIN_ID=
HANIP_ADMIN_PASSWORD_HASH=
HANIP_ADMIN_PASSWORD_PEPPER=replace_with_a_long_random_admin_password_secret
HANIP_ADMIN_SESSION_SECRET=replace_with_a_different_long_random_admin_session_secret
HANIP_ADMIN_PUBLIC_ENABLED=false
HANIP_RETENTION_CRON_CONFIGURED=false
# Server-only pre-provisioned credential adapter. Never place a plaintext PIN here.
HANIP_STUDENT_ACCOUNTS_JSON=[]
NEXT_PUBLIC_HANIP_REPOSITORY_PROVIDER=local
NEXT_PUBLIC_FIREBASE_USE_EMULATOR=false
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_CLIENT_EMAIL=
# Optional explicit Admin project ID. If set, it must equal NEXT_PUBLIC_FIREBASE_PROJECT_ID.
FIREBASE_PROJECT_ID=
# Preserve literal \\n sequences when registering this multiline key in Vercel.
FIREBASE_PRIVATE_KEY=
